{
  "expo": {
    "name": "MarkerApp",
    "slug": "markerapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alemenomarkerapp"
    },
    "android": {
      "package": "com.alemenomarkerapp",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MarkerApp to access your camera to scan custom markers."
        }
      ]
    ]
  }
}
